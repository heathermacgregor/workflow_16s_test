# =================================================================== #
#                       SNAKEMAKE WORKFLOW FOR 16S                      #
# =================================================================== #
import pandas as pd

# 1. Load configuration from the YAML file
configfile = "../../config/config.yaml"

# Helper function to get all the subset IDs that will be generated by the partitioning rule.
# Snakemake needs to know the final targets before it starts.
def get_all_subsets(wildcards):
    return pd.read_csv(
        "results/all_subset_ids.txt", header=None
    )[0].tolist()

# ============================= TARGET RULE =========================== #

# This is the 'master' rule. It defines the final files we want to create.
# Snakemake will work backward from here to figure out what needs to be run.
rule all:
    input:
        # We want the final QIIME2 taxonomy file for every single subset.
        expand("results/{subset}/qiime2/taxonomy/taxonomy.tsv", subset=get_all_subsets)

# ============================ WORKFLOW RULES ========================= #

# Rule 1: Partition datasets into subsets and handle NFC logic.
# This rule runs once and generates a list of all subsets to be processed.
rule partition_datasets:
    input:
        dataset_list = config["paths"]["dataset_list"],
        dataset_info = config["paths"]["dataset_info"],
        script = "scripts/01_partition.py"
    output:
        # This file will contain one subset ID per line. It's used by the `get_all_subsets` helper.
        subset_list = "results/all_subset_ids.txt",
        # We also create a 'touch' file for each subset's raw metadata to trigger the next rule.
        raw_metadata = expand("results/{subset}/raw_data/metadata.tsv", subset=get_all_subsets)
    params:
        project_dir = "results"
    conda:
        "envs/main.yaml"
    shell:
        """
        python {input.script} \
            --config ../config/config.yaml \
            --project-dir {params.project_dir} \
            --output-list {output.subset_list}
        """

# Rule 2: Process metadata for each subset (NFC matching, cleaning, environmental data).
# This rule runs for each `{subset}` wildcard.
rule process_metadata:
    input:
        raw_metadata = "results/{subset}/raw_data/metadata.tsv",
        script = "scripts/02_process_metadata.py"
    output:
        processed_metadata = "results/{subset}/processed_metadata.tsv"
    params:
        subset_id = "{subset}"
    conda:
        "envs/main.yaml"
    shell:
        """
        python {input.script} \
            --config ../config/config.yaml \
            --subset-id "{params.subset_id}" \
            --input-metadata {input.raw_metadata} \
            --output-metadata {output.processed_metadata}
        """

# Rule 3: Process sequences and generate the QIIME2 manifest file.
rule process_sequences_and_manifest:
    input:
        metadata = "results/{subset}/processed_metadata.tsv",
        script = "scripts/03_process_sequences.py"
    output:
        manifest = "results/{subset}/qiime2/manifest.tsv"
    params:
        subset_id = "{subset}",
        subset_dir = "results/{subset}"
    conda:
        "envs/main.yaml"
    shell:
        """
        python {input.script} \
            --config ../config/config.yaml \
            --subset-id "{params.subset_id}" \
            --subset-dir {params.subset_dir} \
            --metadata {input.metadata} \
            --output-manifest {output.manifest}
        """

# Rule 4: Run the main QIIME2 pipeline.
rule run_qiime2:
    input:
        manifest = "results/{subset}/qiime2/manifest.tsv",
        metadata = "results/{subset}/processed_metadata.tsv",
        script = "scripts/04_run_qiime.py"
    output:
        table = "results/{subset}/qiime2/table/feature-table.biom",
        rep_seqs = "results/{subset}/qiime2/rep_seqs/dna-sequences.fasta",
        taxonomy = "results/{subset}/qiime2/taxonomy/taxonomy.tsv"
    params:
        subset_id = "{subset}",
        qiime_dir = "results/{subset}/qiime2"
    conda:
        # It's best practice to have a dedicated environment for heavy tools like QIIME2.
        # You could create a separate `envs/qiime2.yaml` for this.
        "envs/main.yaml"
    threads: 8 # Specify how many threads this job can use
    shell:
        """
        python {input.script} \
            --config ../config/config.yaml \
            --subset-id "{params.subset_id}" \
            --qiime-dir {params.qiime_dir} \
            --metadata {input.metadata} \
            --manifest {input.manifest}
        """